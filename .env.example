# mcp-rosreestr — env vars (all optional for the open client)
#
# Copy to .env in your project root, or export in your shell, then run:
#     atomno-mcp-rosreestr
#
# None of these are required for the open MIT lookups. They tune timeouts,
# cache location, anti-bot, and (later) Pro features.
#
# Canonical names use MCP_ROSREESTR_* prefix (see MCP_BUILD_CHECKLIST).
# Legacy ROSREESTR_* names still work with DeprecationWarning.

# HTTP timeout for upstream calls (seconds, default: 15)
MCP_ROSREESTR_HTTP_TIMEOUT=15

# Where to put the local SQLite cache (default: ./mcp_rosreestr_cache.sqlite)
MCP_ROSREESTR_CACHE_PATH=./mcp_rosreestr_cache.sqlite

# Cache TTLs (seconds). 24h for live values, 7d for static (year built, area).
MCP_ROSREESTR_CACHE_TTL_LIVE=86400
MCP_ROSREESTR_CACHE_TTL_STATIC=604800

# Custom User-Agent for upstream (default identifies the package transparently).
# MCP_ROSREESTR_USER_AGENT=atomno-mcp-rosreestr/0.1.0 (+https://github.com/atomno-mcp/mcp-rosreestr)

# Pro features (api.atomno-mcp.ru/rosreestr) — leave empty for the free client.
# MCP_ROSREESTR_API_KEY=

# DaData fallback for address normalisation (paid, ~0.10 RUB/req).
# Leave empty to skip.
# DADATA_API_KEY=
# DADATA_SECRET_KEY=

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MCP_ROSREESTR_LOG_LEVEL=INFO
